{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Links",
  "version": "0.1.0",
  "identifier": "com.links.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "label": "main",
        "width": 900,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay"
      },
      {
        "label": "quick-add",
        "title": "\u200B",
        "url": "quick-add.html",
        "width": 480,
        "height": 500,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "alwaysOnTop": true,
        "resizable": false,
        "closable": false,
        "minimizable": false,
        "maximizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "bundleName": "Links"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": true
    }
  }
}
